{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend (.NET API)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "backend: build",
      "program": "${workspaceFolder}/backend/src/Kodvian.Core.Api/bin/Debug/net8.0/Kodvian.Core.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/backend/src/Kodvian.Core.Api",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Now listening on:\\s+(https?://\\S+)"
      }
    },
    {
      "name": "Frontend (Angular)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/frontend/src",
      "preLaunchTask": "frontend: start"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (API + Angular)",
      "configurations": [
        "Backend (.NET API)",
        "Frontend (Angular)"
      ],
      "stopAll": true
    }
  ]
}
